NEXT_PUBLIC_API_URL=http://localhost:8001
# Optional: when set, tapper profiles, matches, and profile photos use Supabase instead of local demo storage.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_TAPPER_PHOTO_BUCKET=tapper-photos
# Optional: when set, tapper profiles and matches use PocketBase REST instead of local demo storage.
# Supabase takes precedence when both providers are configured.
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
