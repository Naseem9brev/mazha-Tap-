# Required for Vercel previews and production marketplace persistence.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# Optional: override the default Supabase Storage bucket for tapper profile photos.
NEXT_PUBLIC_SUPABASE_TAPPER_PHOTOS_BUCKET=tapper-photos

# No separate FastAPI service is required for the Vercel-only Next.js deployment.
# Legacy local-only backend development can still set this while backend routes exist:
# NEXT_PUBLIC_API_URL=http://localhost:8001
