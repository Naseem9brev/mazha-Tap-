NEXT_PUBLIC_API_URL=http://localhost:8001

# ──────────────────────────────────────────────────────────────────────────────
# Supabase — shared persistence for the Tapper Marketplace.
# When BOTH variables are set the frontend uses Supabase (tappers table, matches
# table, profile-photos storage bucket). When absent, falls back to localStorage
# with seed data for demo/offline usage.
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Legacy PocketBase (deprecated — kept for reference; remove once migration done)
# NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
