# Leave unset for the Vercel-only Next.js API routes under /api.
# Set only when intentionally pointing the frontend at a separately hosted legacy FastAPI backend.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Required for production marketplace login, shared profiles, matches, and photo storage.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
