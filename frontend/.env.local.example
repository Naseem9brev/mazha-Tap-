NEXT_PUBLIC_API_URL=http://localhost:8001
# Optional: when set, grower/tapper auth uses Supabase Auth. When omitted, the
# marketplace keeps a local demo sign-in so frontend flows stay demoable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: when set, tapper profiles and matches use PocketBase REST instead of local demo storage.
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
